items.Rock_Gem_Quartz.name=Quartz
items.Ingredient_Crystal_Blank.name=Essence Crystal
	items.Ingredient_Crystal_Blank.description=<i>Something lingers inside.</i>\n \nA resource found across many cultures, though its purpose remains unknown.

items.Jewel_Diamond.name=Divinity Jewel
	items.Jewel_Diamond.description=<b><color is="#ffffff">Grants the <color is="#96f9ff">Divinity</color> effects to socketed gear.</color></b>\n<i>It feels as if the power of Gaia is contained within.</i>
items.Jewel_Emerald.name=Sturdy Jewel
	items.Jewel_Emerald.description=<b><color is="#ffffff">Grants the <color is="#42c217">Browny</color> effects to socketed gear.</color></b>\n<i>This gem seems to contain the essence of earth.</i>
items.Jewel_Ruby.name=Power Jewel
	items.Jewel_Ruby.description=<b><color is="#ffffff">Grants the <color is="#ff2717">Powerful</color> effects to socketed gear.</color></b>\n<i>This gem seems to contain the essence of fire.</i>
items.Jewel_Sapphire.name=Intuition Jewel
	items.Jewel_Sapphire.description=<b><color is="#ffffff">Grants the <color is="#326be6">Intuitive</color> effects to socketed gear.</color></b>\n<i>This gem seems to contain the essence of water.</i>
items.Jewel_Topaz.name=Strike Jewel
	items.Jewel_Topaz.description=<b><color is="#ffffff">Grants the <color is="#dec310">Striking</color> effects to socketed gear.</color></b>\n<i>This gem seems to contain the essence of lightning.</i>
items.Jewel_Voidstone.name=Void Jewel
	items.Jewel_Voidstone.description=<b><color is="#ffffff">Grants the <color is="#a217ff">Draining</color> effects to socketed gear.</color></b>\n<i>It feels like the power of an evil entity is contained within.</i>
items.Jewel_Zephyr.name=Swiftness Jewel
	items.Jewel_Zephyr.description=<b><color is="#ffffff">Grants the <color is="#10b8de">Swifty</color> effects to socketed gear.</color></b>\n<i>This gem seems to contain the essence of wind.</i>
items.Jewel_Quartz.name=Life Jewel
	items.Jewel_Quartz.description=<b><color is="#ffffff">Grants the <color is="#ffd2f7">Vigorous</color> effects to socketed gear.</color></b>\n<i>This gem seems to contain the essence of life.</i>


items.Bench_Socketing.name=Jeweler's Forge
items.Bench_Socketing.description=Used to upgrade gear by socketing gems on them.\n \n<i>Arcanists once worked with jewelers to create equipment imbued with the powers of the elements, forging elite soldiers. Since then, no one has been able to harness the power of gems... Until now</i>
